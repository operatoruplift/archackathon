# ── Frontend (Vite) ──────────────────────────────────────────────
# Leave everything blank to run in Demo Mode (local state, simulated mints).

# Supabase project (production path — Postgres, Auth, Edge Functions)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional DAS-capable devnet RPC (e.g. Helius free tier) used to enrich
# reward badges with live on-chain metadata. Plain devnet RPC does not
# support DAS, so this is optional — the app falls back to Supabase rows.
VITE_DAS_RPC_URL=

# ── Vercel serverless mint fallback (/api/mint-reward-cnft) ─────
# Lets the deployed demo mint REAL devnet cNFTs without Supabase.
# Set these in the Vercel project → Settings → Environment Variables.
SOLANA_RPC_URL=https://api.devnet.solana.com
MERKLE_TREE_ADDRESS=
COLLECTION_MINT_ADDRESS=
# base58-encoded secret key of the funded devnet payer (devnet only!)
PAYER_SECRET_KEY=
# public origin allowed to call the mint API, e.g. https://crystalz.vercel.app
MINT_ALLOWED_ORIGIN=

# ── Supabase Edge Function secrets (supabase secrets set ...) ───
# SOLANA_RPC_URL, MERKLE_TREE_ADDRESS, COLLECTION_MINT_ADDRESS,
# PAYER_SECRET_KEY, plus:
# WALLET_ENC_KEY=   # 32-byte base64 key for AES-GCM custodial wallet encryption
